# ===========================================
# AI Web - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:***@host/database?sslmode=require"

# kie.ai API (for image generation)
# Get your API key at https://kie.ai/api-key
# Models: GPT Image 2, Nano Banana, Nano Banana Pro
KIE_API_KEY=***

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=***

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
