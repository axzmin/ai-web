// AI Web Prisma Schema
// Neon PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique  // Clerk User ID
  email     String   @unique
  name      String?
  image     String?
  credits   Int      @default(25)  // Free credits on registration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?
  generations Generation[]
  creditLogs  CreditLog[]
}

model Generation {
  id           String   @id @default(cuid())
  prompt       String
  imageUrl     String
  thumbnailUrl String?
  model        String   @default("gpt-image-2")
  aspectRatio  String   @default("auto")
  quality      String   @default("1K")
  creditsCost  Int      @default(2)
  seed         Int?
  steps        Int?
  status       String   @default("completed")
  type         String   @default("text-to-image") // "text-to-image" | "image-to-image"
  inputImageUrl String? // For I2I: user's uploaded input image (first one only)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isPublic     Boolean  @default(false)
  galleryItem  GalleryItem?
  creditLog    CreditLog?
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

// Credits流水日志 / Credit transaction ledger
model CreditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // 'earn' | 'spend' | 'refund' | 'bonus'
  amount      Int      // 正数 = 增加, 负数 = 减少 (spend用负数记录)
  balanceAfter Int     // 变动后余额
  description String   @default("") // 备注
  generationId String? @unique
  generation  Generation? @relation(fields: [generationId], references: [id])
  createdAt   DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String?
  description String?
  imageUrl    String
  prompt      String
  seed        Int?
  tags        String[]
  generationId String? @unique
  generation   Generation? @relation(fields: [generationId], references: [id])
  createdAt   DateTime @default(now())
  @@index([tags])
  @@index([createdAt])
}
